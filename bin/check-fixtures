#!/usr/bin/env php
<?php

/**
 * Validate that visual test fixtures are in sync between terminals.
 *
 * Checks that:
 * 1. Every iTerm fixture has a corresponding Ghostty fixture (and vice versa)
 * 2. Matching fixtures have identical content
 *
 * Usage:
 *   composer test:fixtures    Check fixture sync status
 */

$fixturesDir = __DIR__ . '/../tests/Fixtures';
$errors = [];
$warnings = [];
$checked = 0;
$dimensionErrors = [];
$dimensionsChecked = 0;

// Required fixture dimensions (must match CI environment)
const REQUIRED_WIDTH = 180;
const REQUIRED_HEIGHT = 32;

echo "Checking fixture dimensions (" . REQUIRED_WIDTH . "x" . REQUIRED_HEIGHT . ")...\n\n";

// Check dimensions for all terminal fixtures
$dimensionsChecked += checkFixtureDimensions($fixturesDir . '/iterm', $dimensionErrors);
$dimensionsChecked += checkFixtureDimensions($fixturesDir . '/ghostty', $dimensionErrors);

if (count($dimensionErrors) > 0) {
    echo "DIMENSION ERRORS FOUND:\n\n";
    foreach ($dimensionErrors as $error) {
        echo "  ✗ {$error}\n";
    }
    echo "\n";
    echo "Found " . count($dimensionErrors) . " fixture dimension error(s).\n";
    echo "All fixtures must be generated at " . REQUIRED_WIDTH . "x" . REQUIRED_HEIGHT . ".\n";
    echo "Resize your terminal and run: composer test:screenshots\n";
    exit(1);
}

echo "✓ All {$dimensionsChecked} fixture(s) have correct dimensions.\n\n";

echo "Checking terminal fixture synchronization...\n\n";

// Check screenshot fixtures (tests/Fixtures/{iterm,ghostty}/...)
$checked += checkFixtureDirectory(
    $fixturesDir . '/iterm',
    $fixturesDir . '/ghostty',
    'iterm',
    'ghostty',
    $errors,
    $warnings
);

// Check render fixtures (tests/Fixtures/Renders/{iterm,ghostty}/...)
$checked += checkFixtureDirectory(
    $fixturesDir . '/Renders/iterm',
    $fixturesDir . '/Renders/ghostty',
    'iterm',
    'ghostty',
    $errors,
    $warnings
);

if (count($errors) > 0) {
    echo "ERRORS FOUND:\n\n";
    foreach ($errors as $error) {
        echo "  ✗ {$error}\n";
    }
    echo "\n";
    echo "Found " . count($errors) . " fixture validation error(s).\n";
    echo "All visual tests must be run in both iTerm and Ghostty.\n";
    echo "Fixtures must produce identical output in both terminals.\n";
    exit(1);
}

if ($checked === 0) {
    echo "No terminal-specific fixtures found to validate.\n";
} else {
    echo "✓ All {$checked} fixture pair(s) validated successfully.\n";
}

if (count($warnings) > 0) {
    echo "\nWARNINGS:\n\n";
    foreach ($warnings as $warning) {
        echo "  ! {$warning}\n";
    }
    echo "\n";
    echo "Found " . count($warnings) . " warning(s).\n";
    echo "Checksum-only drift does not affect rendering parity, but consider regenerating fixtures to normalize metadata.\n";
}

exit(0);

/**
 * Check fixtures in a directory pair (e.g., iterm vs ghostty).
 *
 * @return int Number of fixture pairs checked
 */
function checkFixtureDirectory(
    string $dir1,
    string $dir2,
    string $name1,
    string $name2,
    array &$errors,
    array &$warnings
): int {
    $checked = 0;

    // Check dir1 -> dir2
    if (is_dir($dir1)) {
        $files = findJsonFiles($dir1);
        foreach ($files as $file) {
            $relPath = substr($file, strlen($dir1) + 1);
            $otherFile = $dir2 . '/' . $relPath;

            if (!file_exists($otherFile)) {
                $errors[] = "Missing {$name2} fixture for: {$relPath}";
            } else {
                $comparison = compareFixtureFiles($file, $otherFile);

                if ($comparison['match']) {
                    $checked++;

                    if ($comparison['checksumOnly']) {
                        $warnings[] = "Checksum differs across terminals for: {$relPath}";
                    }
                } else {
                    $errors[] = "Fixture mismatch between terminals for: {$relPath} ({$comparison['reason']})";
                }
            }
        }
    }

    // Check dir2 -> dir1 (only for missing files, matches already checked)
    if (is_dir($dir2)) {
        $files = findJsonFiles($dir2);
        foreach ($files as $file) {
            $relPath = substr($file, strlen($dir2) + 1);
            $otherFile = $dir1 . '/' . $relPath;

            if (!file_exists($otherFile)) {
                $errors[] = "Missing {$name1} fixture for: {$relPath}";
            }
        }
    }

    return $checked;
}

/**
 * Recursively find all JSON files in a directory.
 */
function findJsonFiles(string $dir): array
{
    $files = [];

    if (!is_dir($dir)) {
        return $files;
    }

    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($dir, RecursiveDirectoryIterator::SKIP_DOTS)
    );

    foreach ($iterator as $file) {
        if ($file->isFile() && $file->getExtension() === 'json') {
            $files[] = $file->getPathname();
        }
    }

    return $files;
}

/**
 * Compare fixture files semantically.
 *
 * For terminal fixtures, width/height/output must match. Checksum is ignored
 * for parity checks so legacy checksum algorithm migrations don't fail CI.
 *
 * For render fixtures, output must match.
 *
 * @return array{match: bool, reason: string, checksumOnly: bool}
 */
function compareFixtureFiles(string $file1, string $file2): array
{
    $raw1 = file_get_contents($file1);
    $raw2 = file_get_contents($file2);

    if ($raw1 === false || $raw2 === false) {
        return [
            'match' => false,
            'reason' => 'could not read fixture file',
            'checksumOnly' => false,
        ];
    }

    if ($raw1 === $raw2) {
        return [
            'match' => true,
            'reason' => '',
            'checksumOnly' => false,
        ];
    }

    $data1 = json_decode($raw1, true);
    $data2 = json_decode($raw2, true);

    if (!is_array($data1) || !is_array($data2)) {
        return [
            'match' => false,
            'reason' => 'raw JSON differs',
            'checksumOnly' => false,
        ];
    }

    $isTerminalFixture1 = array_key_exists('width', $data1)
        || array_key_exists('height', $data1)
        || array_key_exists('checksum', $data1);
    $isTerminalFixture2 = array_key_exists('width', $data2)
        || array_key_exists('height', $data2)
        || array_key_exists('checksum', $data2);

    if ($isTerminalFixture1 || $isTerminalFixture2) {
        $terminalFields = ['width', 'height', 'output'];

        foreach ($terminalFields as $field) {
            if (!array_key_exists($field, $data1) || !array_key_exists($field, $data2)) {
                return [
                    'match' => false,
                    'reason' => "missing '{$field}' in terminal fixture payload",
                    'checksumOnly' => false,
                ];
            }

            if ($data1[$field] !== $data2[$field]) {
                return [
                    'match' => false,
                    'reason' => "terminal fixture '{$field}' differs",
                    'checksumOnly' => false,
                ];
            }
        }

        $checksumOnly = ($data1['checksum'] ?? null) !== ($data2['checksum'] ?? null);

        return [
            'match' => true,
            'reason' => '',
            'checksumOnly' => $checksumOnly,
        ];
    }

    if (array_key_exists('output', $data1) && array_key_exists('output', $data2)) {
        if ($data1['output'] !== $data2['output']) {
            return [
                'match' => false,
                'reason' => 'render fixture output differs',
                'checksumOnly' => false,
            ];
        }

        return [
            'match' => true,
            'reason' => '',
            'checksumOnly' => false,
        ];
    }

    return [
        'match' => false,
        'reason' => 'unrecognized fixture payload shape',
        'checksumOnly' => false,
    ];
}

/**
 * Check that all fixtures in a directory have the required dimensions.
 *
 * @return int Number of fixtures checked
 */
function checkFixtureDimensions(string $dir, array &$errors): int
{
    $checked = 0;

    if (!is_dir($dir)) {
        return $checked;
    }

    $files = findJsonFiles($dir);
    foreach ($files as $file) {
        $data = json_decode(file_get_contents($file), true);

        if (!isset($data['width']) || !isset($data['height'])) {
            continue;
        }

        $checked++;

        if ($data['width'] !== REQUIRED_WIDTH || $data['height'] !== REQUIRED_HEIGHT) {
            $relPath = basename(dirname($dir)) . '/' . basename($dir) . '/' . substr($file, strlen($dir) + 1);
            $errors[] = "{$relPath}: {$data['width']}x{$data['height']} (expected " . REQUIRED_WIDTH . "x" . REQUIRED_HEIGHT . ")";
        }
    }

    return $checked;
}
